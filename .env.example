# Shared local defaults for CareerPilot-AI.
# Copy this file to .env only when a root-level tool needs shared values.

CAREERPILOT_ENVIRONMENT=local
CAREERPILOT_DEBUG=false
CAREERPILOT_API_VERSION=0.1.0
CAREERPILOT_LOG_LEVEL=INFO
CAREERPILOT_CORS_ORIGINS=["http://localhost:5173"]

# Frontend
VITE_API_BASE_URL=http://localhost:8000
